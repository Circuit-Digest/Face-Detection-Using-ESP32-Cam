// FIX 5: stream directly over the raw WiFiClient, not server.sendContent()
void handleStream() {
  WiFiClient streamClient = server.client();

  streamClient.print(
    "HTTP/1.1 200 OK\r\n"
    "Content-Type: multipart/x-mixed-replace; boundary=frame\r\n"
    "Cache-Control: no-cache\r\n"
    "Connection: close\r\n\r\n");

  const uint32_t FRAME_GAP_MS = 80;   // ~12 fps
  const uint32_t WATCHDOG_MS  = 8000; // reset if no frame sent for 8 s
  uint32_t lastFrame = millis();

  while (streamClient.connected()) {
    if (millis() - lastFrame > WATCHDOG_MS) {
      Serial.println("[STREAM] watchdog timeout");
      break;
    }

    camera_fb_t* fb = esp_camera_fb_get();
    if (!fb) { vTaskDelay(pdMS_TO_TICKS(10)); continue; }

    streamClient.print("--frame\r\nContent-Type: image/jpeg\r\nContent-Length: ");
    streamClient.print(fb->len);
    streamClient.print("\r\n\r\n");
    size_t written = streamClient.write(fb->buf, fb->len);
    streamClient.print("\r\n");
    esp_camera_fb_return(fb);

    if (written == 0) { Serial.println("[STREAM] write 0 — client gone"); break; }
    lastFrame = millis();
    vTaskDelay(pdMS_TO_TICKS(FRAME_GAP_MS));
  }

  streamClient.stop();
  Serial.println("[STREAM] client disconnected");
}

// Web server task runs on Core 1 (same core as loop)
void webTask(void* /*arg*/) {
  for (;;) {
    server.handleClient();
    vTaskDelay(pdMS_TO_TICKS(2));
  }
}

// ─── Setup ────────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  vTaskDelay(pdMS_TO_TICKS(300));
  Serial.println("\n=== ESP32-CAM Face Detection ===");

  // Ultrasonic
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  digitalWrite(TRIG_PIN, LOW);

  // Camera
  if (!initCamera()) {
    Serial.println("[CAM] fatal — check wiring");
    while (true) vTaskDelay(pdMS_TO_TICKS(1000));
  }

  // FIX 9: create mutex before any task can use the buffer
  g_imgMutex = xSemaphoreCreateMutex();

  // FIX 7: create semaphores BEFORE spawning the network task
  g_startSem = xSemaphoreCreateBinary();
  g_doneSem  = xSemaphoreCreateBinary();

  // WiFi
  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  Serial.print("[WiFi] connecting");
  for (uint32_t t = millis(); WiFi.status() != WL_CONNECTED;) {
    if (millis() - t > 30000) { Serial.println("\ntimeout → reboot"); ESP.restart(); }
    vTaskDelay(pdMS_TO_TICKS(500));
    Serial.print(".");
  }
  Serial.printf("\n[WiFi] %s\n", WiFi.localIP().toString().c_str());
  Serial.printf("[WEB]  http://%s/\n", WiFi.localIP().toString().c_str());

  // FIX 4: NTP for IST timestamps
  esp_sntp_setoperatingmode(SNTP_OPMODE_POLL);
  esp_sntp_setservername(0, "pool.ntp.org");
  esp_sntp_setservername(1, "time.nist.gov");
  esp_sntp_init();
  setenv("TZ", "IST-5:30", 1);
  tzset();
  Serial.print("[NTP] syncing");
  for (int i = 0; i < 20 && sntp_get_sync_status() != SNTP_SYNC_STATUS_COMPLETED; i++) {
    vTaskDelay(pdMS_TO_TICKS(500)); Serial.print(".");
  }
  Serial.println(sntp_get_sync_status() == SNTP_SYNC_STATUS_COMPLETED ? " OK" : " (timeout)");

  // Web server routes
  server.on("/",       handleRoot);
  server.on("/stream", HTTP_GET, handleStream);
  server.begin();
  Serial.println("[WEB] server started");

  // FIX 7: network task on Core 0 (WiFi stack lives on Core 0)
  xTaskCreatePinnedToCore(networkTask, "net_task", 8192, nullptr, 5, nullptr, 0);
  // Web task on Core 1 alongside loop()
  xTaskCreatePinnedToCore(webTask,     "web_task", 4096, nullptr, 3, nullptr, 1);

  printHeap("setup complete");
  Serial.println("[READY] Watching for objects < " + String(DETECT_CM) + " cm");
}

// ─── Main Loop — Ultrasonic polling ──────────────────────────────
void loop() {
  static unsigned long lastTrigger = 0;
  static bool networkBusy = false;

  float dist = getDistance();

  // Print distance only when it changes meaningfully (reduces serial spam)
  static float lastPrinted = -1;
  if (fabs(dist - lastPrinted) > 2.0f && dist < 200.0f) {
    Serial.printf("[US] %.1f cm\n", dist);
    lastPrinted = dist;
  }

  if (dist < (float)DETECT_CM && !networkBusy &&
      millis() - lastTrigger > COOLDOWN) {
    lastTrigger = millis();
    Serial.printf("\n[TRIGGER] %.1f cm — capturing\n", dist);
    printHeap("before capture");

    if (captureFrame()) {
      printHeap("after capture");
      networkBusy = true;
      strncpy(g_status, "Detecting...", sizeof(g_status));

      xSemaphoreGive(g_startSem);

      // Wait for network task to finish, keep web server alive
      uint32_t tWait = millis();
      while (xSemaphoreTake(g_doneSem, pdMS_TO_TICKS(50)) != pdTRUE) {
        if (millis() - tWait > 35000) {
          Serial.println("[LOOP] network timeout — continuing");
          break;
        }
      }
      networkBusy = false;
      Serial.printf("[LOOP] done: %s\n", g_status);
    }
  }

  delay(100);
}
