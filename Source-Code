#define ECHO_PIN   15
#define DETECT_CM  10       // trigger distance threshold
#define COOLDOWN   8000UL   // ms between triggers

// ─── Camera Pins (AI-Thinker ESP32-CAM) ──────────────────────────
#define PWDN_GPIO_NUM   32
#define RESET_GPIO_NUM  -1
#define XCLK_GPIO_NUM    0
